PORT=5000
# Use port 6543 (Supavisor pooler) for Render and other IPv4-only hosts.
# Port 5432 direct works locally only if your network supports IPv6.
DATABASE_URL="postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:6543/postgres?sslmode=require&pgbouncer=true&connect_timeout=30"
JWT_SECRET="change-me-to-a-long-random-secret"
ADMIN_SECRET_TOKEN="change-me-to-a-long-random-secret"
ADMIN_API_KEY="change-me-to-a-long-random-secret"
HUMBEE_API_KEY="your-humbee-api-key"
HUMBEE_API_URL="https://api-dev.humbee.in/external-system/generate-pwa-module-access"
