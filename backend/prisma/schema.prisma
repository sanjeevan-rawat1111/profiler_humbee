generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Region {
  id           String        @id @default(uuid())
  regionName   String        @unique @map("region_name")
  regionCode   String?       @unique @map("region_code")
  status       String        @default("active")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  regionStates RegionState[]
  userRegions  UserRegion[]

  @@map("regions")
}

model RegionState {
  id       String @id @default(uuid())
  regionId String @map("region_id")
  stateId  String @unique @map("state_id")
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@index([regionId])
  @@map("region_states")
}

model UserRegion {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  regionId String @map("region_id")
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  region   Region @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([userId, regionId])
  @@index([userId])
  @@index([regionId])
  @@map("user_regions")
}

model User {
  id            String       @id @default(uuid())
  name          String
  mobileNumber  String       @unique @map("mobile_number")
  passwordHash  String       @map("password_hash")
  plainPassword String?      @map("plain_password")
  role          String       @default("user") // "user", "admin", or "manager"
  region        String
  stateId       String?      @map("state_id")
  districtId    String?      @map("district_id")
  state         String       @default("")
  district      String       @default("")
  status        String       @default("active") // "active" or "inactive"
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  submissions   Submission[]
  auditLogs     AuditLog[]
  userRegions   UserRegion[]

  @@map("users")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  username  String
  name      String?
  region    String?
  state     String?
  district  String?
  eventType String   @map("event_type") // LOGIN | LOGOUT
  status    String   // SUCCESS | FAIL
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model Submission {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  sapCode      String   @map("sap_code")
  mobileNumber String   @map("mobile_number")
  submittedAt  DateTime @default(now()) @map("submitted_at")
  pwaUrl       String   @map("pwa_url")
  apiResponse  String   @map("api_response") // Store complete JSON payload from the API response
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("submissions")
}
